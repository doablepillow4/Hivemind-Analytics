{
  "name": "testai",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm run dev:full",
    "dev:all": "pnpm run dev:full",
    "dev:full": "concurrently \"pnpm run db:up\" \"pnpm run dev:servers\" --kill-others-on-fail",
    "dev:servers": "wait-on tcp:5432 && pnpm run db:push && concurrently \"pnpm run api:dev\" \"pnpm run frontend:dev\"",
    "db:up": "docker compose up -d postgres",
    "db:push": "pnpm --filter @workspace/db run push",
    "api:dev": "PORT=8080 pnpm --filter @workspace/api-server run dev",
    "frontend:dev": "PORT=5173 pnpm --filter @workspace/hivemind run dev -- --host 0.0.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "wait-on": "^8.0.0"
  }
}